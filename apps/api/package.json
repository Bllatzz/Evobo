    "@prisma/client": "^6.19.1",
    "@supabase/supabase-js": "^2.110.0",
    "bullmq": "^5.79.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "dotenv": "^16.6.1",
