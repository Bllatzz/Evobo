# Postgres — pooled (app queries) vs direct (migrations). Both point at the
# Supabase local stack in dev (`supabase start` inside apps/api).
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# Supabase project (local stack values printed by `supabase start`; real
# values in prod). SERVICE_ROLE_KEY must never reach the frontend bundle.
SUPABASE_URL="http://localhost:54321"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Read by the Supabase CLI itself (config.toml's env() substitution) for
# the "Continuar com Google" button — not consumed by our Node app.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=""
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=""

REDIS_URL="redis://localhost:6379"

# Robô de Apostas proxies robotip's own live alerts API — see
# apps/api/src/modules/robot-signals/routes.ts. Defaults to the deployed
# Fly.io instance if unset. ROBOTIP_API_KEY is required by that backend
# (X-API-Key header) since it was found wide open to the internet; get the
# value from robotip/backend/.env's API_KEY. Optional here — a missing key
# just makes the robot-signals routes report "unavailable", it doesn't
# crash the API.
ROBOTIP_API_URL="https://robotip-analyzer.fly.dev"
ROBOTIP_API_KEY=""

# Pix key that receives all manual VIP payments (no PSP) — see project
# memory "payments-manual-pix". Platform-owned, not per-tipster.
PIX_KEY=""
PIX_RECEIVER_NAME=""
PIX_RECEIVER_CITY=""


# Neo IA (robotip.com.br) — not wired up yet (src/modules/neoia-scraper).
# Requires login; free tier is capped at 6 AI credits/day, so cache
# aggressively once this is filled in.
NEOIA_EMAIL=""
NEOIA_PASSWORD=""

PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
